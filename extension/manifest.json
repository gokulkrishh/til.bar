{
  "manifest_version": 3,
  "name": "til.bar",
  "description": "Save links to til.bar with one click",
  "version": "1.2.0",
  "permissions": ["activeTab", "contextMenus", "storage", "scripting"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png"
    },
    "default_title": "Save to til.bar"
  }
}
